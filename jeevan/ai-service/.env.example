# AI Service Environment Variables

# Groq API Configuration
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Redis Configuration (optional - defaults to localhost:6379)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py

# Application Settings
# Port to run the application on (default: 5000)
# PORT=5000

# Rate Limiting (configured in code, but can be overridden)
# RATE_LIMIT_DEFAULT=100 per minute
# RATE_LIMIT_DESCRIBE=10 per minute
# RATE_LIMIT_RECOMMEND=10 per minute
# RATE_LIMIT_REPORT=5 per minute

# Caching TTL (in seconds, default: 900 = 15 minutes)
# CACHE_TTL=900